{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep,
 ;; all .cljc -> portable to JVM / SCI / ClojureScript / GraalVM).
 ;; Pinned by git/sha so this repo is standalone-forkable (no
 ;; monorepo-relative :local/root assumption) -- ISIC-3700 needs no
 ;; robotics (blueprint.edn :itonami.blueprint/robotics false: this
 ;; is a back-office coordination actor, never a physical-actuation
 ;; one -- it never directly operates pump/valve equipment and never
 ;; makes a public-health-authority discharge decision).
 :deps {io.github.kotoba-lang/langgraph
        {:git/sha "a332a770a0d2b5193f81b54483bb954fb29ef8d7"}}
 :aliases
 {;; monorepo-internal dev -- pin transitive langgraph/langchain to
  ;; local checkouts when working inside the com-junkawasaki superproject.
  :dev {:override-deps
        {io.github.kotoba-lang/langgraph
         {:local/root "../../kotoba-lang/langgraph"}
         io.github.kotoba-lang/langchain
         {:local/root "../../kotoba-lang/langchain"}}}
  ;; clojure -M:run  -> drive the demo through one OperationActor
  :run {:main-opts ["-m" "sewerops.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; static analysis -- clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
